// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Repository {
  id              String          @id
  name            String
  path            String?         @unique

  provider        String? // "local" | "github" | "gitlab"
  cloneUrl        String? // git@github.com:... or https://...
  cloneUrlHttps   String? // HTTPS URL for API calls (when cloneUrl is SSH)
  deployKeyCipher String?
  deployKeyIv     String?
  deployKeyTag    String?
  patCipher       String?
  patIv           String?
  patTag          String?
  webhookSecret   String? // HMAC secret (plaintext — needed to verify inbound webhooks)
  webhookId       String?
  lastFetchAt     DateTime?
  localPath       String? // server-managed clone directory

  baseBranch         String
  activeBranch       String
  triggerMode        String
  quietPeriodSeconds Int
  branchPattern      String
  status             String
  lastCommitHash     String
  lastCommitMessage  String
  lastActivityTime   String
  stabilizationTimer Int
  reviewsCount       Int
  indexedAt          String?
  reviewHistory      ReviewHistory[]
  pullRequests       PullRequest[]

  @@map("repositories")
}

model ReviewLog {
  id        String   @id
  prId      String
  message   String
  level     String   // "info" | "warn" | "error" | "tool_call"
  createdAt DateTime @default(now())

  @@index([prId, createdAt])
  @@map("review_logs")
}

model ReviewHistory {
  id            String     @id
  repoId        String
  repoName      String
  branch        String
  commitHash    String
  triggerReason String
  status        String
  timestamp     String
  repository    Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@map("review_history")
}

model PullRequest {
  id             String           @id
  repoId         String
  title          String
  sourceBranch   String
  targetBranch   String
  status         String
  author         String
  commitHash     String
  createdAt      String
  description    String?
  rating         Int?
  repository     Repository       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  prFiles        PrFile[]
  reviewFindings ReviewFinding[]

  @@map("pull_requests")
}

model PrFile {
  id              String      @id
  prId            String
  filename        String
  status          String
  additions       Int
  deletions       Int
  originalContent String?
  modifiedContent String?
  diff            String?
  pullRequest     PullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@unique([prId, filename])
  @@map("pr_files")
}

model ReviewFinding {
  id             String      @id
  prId           String
  repoId         String
  category       String
  severity       String
  filename       String
  line           Int?
  explanation    String
  diffSuggestion String?
  evidenceChain  String?
  confidence     Float?
  timestamp      String
  pullRequest    PullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@map("review_findings")
}

model Symbol {
  id         String  @id
  repoId     String
  filePath   String
  name       String
  kind       String
  language   String
  lineStart  Int
  lineEnd    Int
  signature  String?
  sourceHash String
  summary    String?
  summaryAt  BigInt?
  embedding  Unsupported("vector(1536)")?

  @@map("symbols")
}

model Edge {
  id       String  @id
  repoId   String
  fromId   String
  toId     String?
  toRaw    String?
  kind     String
  filePath String
  line     Int

  @@map("edges")
}

model File {
  repoId   String
  filePath String
  fileHash String
  parsedAt BigInt

  @@id([repoId, filePath])
  @@map("files")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  banned        Boolean   @default(false)
  role          String    @default("user")
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  organizations Organization[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expiresAt    DateTime
  token        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                      String    @id @default(cuid())
  userId                  String
  accountId               String
  providerId              String
  accessToken             String?
  refreshToken            String?
  idToken                 String?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  scope                   String?
  password                String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @updatedAt
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  members     Member[]
  invitations Invitation[]

  @@map("organizations")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model McpApiKey {
  id        String   @id @default(cuid())
  name      String
  prefix    String
  hash      String   @unique
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  revoked   Boolean  @default(false)

  @@map("mcp_api_keys")
}
