#!/bin/sh
# Dragnet pre-push hook
# Installed by: npm run install-hooks  or  npm run dragnet install-hooks
#
# Blocks pushes that fail the Dragnet AI review (rating < 8/10).
# Bypass with: git push --no-verify
#
# Reads branch info from git's pre-push stdin and calls the Dragnet API.
#
# Configuration (set these in your shell/profile or .env):
#   DRAGNET_URL      - default: http://localhost:3300
#   DRAGNET_API_KEY  - your key from Dragnet UI → LLM Settings → API Keys
#                      (or written to .dragnet/cred.json by the install modal)

DRAGNET_URL="${DRAGNET_URL:-http://localhost:3300}"
DRAGNET_API_KEY="${DRAGNET_API_KEY:-}"
REPO_PATH="$(git rev-parse --show-toplevel 2>/dev/null)"

if [ -z "$REPO_PATH" ]; then
  exit 0
fi

# Fall back to .dragnet/cred.json if the env var isn't set (non-interactive
# shells don't source ~/.zshrc, so this is how agents and CI authenticate).
if [ -z "$DRAGNET_API_KEY" ] && [ -f "$REPO_PATH/.dragnet/cred.json" ]; then
  DRAGNET_API_KEY=$(jq -r .key "$REPO_PATH/.dragnet/cred.json" 2>/dev/null)
fi

if [ -z "$DRAGNET_API_KEY" ]; then
  echo "⚠ Dragnet: no API key. Set \$DRAGNET_API_KEY or write .dragnet/cred.json"
  echo "  Generate one from Dragnet UI → LLM Settings → API Keys."
  echo "  Push blocked. Set the key or use --no-verify to bypass."
  exit 1
fi

while read local_ref local_sha remote_ref remote_sha; do
  branch="${local_ref#refs/heads/}"

  case "$branch" in
    main|master|develop) continue ;;
  esac

  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  result=$(curl -s -m 300 "$DRAGNET_URL/api/hooks/prepush" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $DRAGNET_API_KEY" \
    -d "{\"branch\":\"$branch\",\"repoPath\":\"$REPO_PATH\",\"sha\":\"$local_sha\"}")

  passed=$(echo "$result" | grep -o '"passed":[^,}]*' | cut -d: -f2)
  rating=$(echo "$result" | grep -o '"rating":[^,}]*' | cut -d: -f2)
  error=$(echo "$result" | grep -o '"error":"[^"]*"' | head -1 | cut -d\" -f4)
  message=$(echo "$result" | grep -o '"message":"[^"]*"' | head -1 | cut -d\" -f4)
  size_label=$(printf '%s' "$result" | sed -n 's/.*"sizeProfile":{[^}]*"label":"\([^"]*\)".*/\1/p')
  size_message=$(printf '%s' "$result" | sed -n 's/.*"sizeProfile":{[^}]*"message":"\([^"]*\)".*/\1/p')

  if [ -n "$size_label" ]; then
    if [ -n "$size_message" ]; then
      echo "Dragnet size: $size_label - $size_message"
    else
      echo "Dragnet size: $size_label"
    fi
  fi

  if [ "$passed" = "true" ]; then
    echo "✓ Dragnet: branch '$branch' approved ($rating/10)"
  elif [ -n "$error" ]; then
    echo "⚠ Dragnet: $error"
    exit 1
  elif [ -n "$message" ]; then
    echo "$message"
    echo "  Review findings in the Dragnet UI or run '/dragnet fix' in your agent."
    echo "  To bypass: git push --no-verify"
    exit 1
  else
    echo "✗ Dragnet: branch '$branch' blocked ($rating/10 — needs 8+)"
    echo "  Review findings in the Dragnet UI or run '/dragnet fix' in your agent."
    echo "  To bypass: git push --no-verify"
    exit 1
  fi
done

exit 0
